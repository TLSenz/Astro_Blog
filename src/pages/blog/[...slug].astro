---
import '../../styles/global.css';
import { getCollection, type CollectionEntry } from 'astro:content';
import MarkdownRenderer from '../../components/MarkdownRenderer';
import { calculateReadingTime, formatDate, getRelatedPosts } from '../../utils/blog';

export async function getStaticPaths() {
  const blogEntries = await getCollection('blog');
  return blogEntries.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry, allEntries: blogEntries },
  }));
}

type Props = {
  entry: CollectionEntry<'blog'>;
  allEntries: CollectionEntry<'blog'>[];
};

const { entry, allEntries } = Astro.props as Props;
const { title, author, pubDate, tags } = entry.data;

const relatedPosts = getRelatedPosts(entry, allEntries, 2);
const readingTime = calculateReadingTime(entry.body);
---

<html lang="en">
  <body class="min-h-screen bg-black text-white flex flex-col">
    <header class="mx-auto flex w-full max-w-3xl items-center justify-between px-6 py-8">
      <a class="text-sm text-gray-300 transition hover:text-white" href="/">← Back</a>
      <nav class="space-x-5 text-sm text-gray-300">
        <a class="transition hover:text-white" href="/">Home</a>
        <a class="transition hover:text-white" href="/about">About</a>
      </nav>
    </header>

    <main class="flex-1">
      <MarkdownRenderer
        client:load
        title={title}
        author={author}
        date={pubDate}
        content={entry.body}
      />

      <section class="mx-auto mt-2 w-full max-w-3xl px-4 pb-8">
        <p class="text-sm text-gray-400">{formatDate(pubDate)} · {readingTime} min read</p>
        {tags && tags.length > 0 && (
          <ul class="mt-3 flex flex-wrap gap-2">
            {tags.map((tag) => (
              <li class="rounded-full border border-white/20 px-3 py-1 text-xs text-gray-300 transition hover:border-white/50 hover:text-white">#{tag}</li>
            ))}
          </ul>
        )}
      </section>

      {relatedPosts.length > 0 && (
        <section class="mx-auto mb-12 w-full max-w-3xl px-4">
          <h2 class="mb-3 text-base font-semibold">Related posts</h2>
          <ul class="space-y-3">
            {relatedPosts.map((post) => (
              <li>
                <a
                  class="block rounded-lg border border-white/15 bg-white/5 px-4 py-3 transition duration-300 hover:-translate-y-0.5 hover:border-white/40 hover:bg-white/10"
                  href={`/blog/${post.slug}`}
                >
                  <span class="text-sm">{post.data.title}</span>
                </a>
              </li>
            ))}
          </ul>
        </section>
      )}
    </main>

    <footer class="pb-6">
      <div class="w-full flex justify-center">
        <a href="https://github.com/tlsenz" class="transition hover:opacity-80">
          <img src="/social.png" alt="Logo" class="w-8 h-8" />
        </a>
      </div>
    </footer>
  </body>
</html>
