---
import '../../styles/global.css';
import { getCollection } from 'astro:content';
import MarkdownRenderer from '../../components/MarkdownRenderer';
import { calculateReadingTime, formatDate, getRelatedPosts } from '../../utils/blog';

export async function getStaticPaths() {
  const blogEntries = await getCollection('blog');
  return blogEntries.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry, allEntries: blogEntries },
  }));
}

const { entry, allEntries } = Astro.props;
const { title, author, pubDate, tags } = entry.data;

const relatedPosts = getRelatedPosts(entry, allEntries, 2);
const readingTime = calculateReadingTime(entry.body);
---

<html lang="en">
  <body class="min-h-screen bg-black text-white flex flex-col">
    <header class="mx-auto flex w-full max-w-4xl items-center justify-between px-6 py-6">
      <a class="text-sm text-gray-300 hover:underline" href="/">← Back to posts</a>
      <nav class="space-x-4 text-sm">
        <a class="hover:underline" href="/">Home</a>
        <a class="hover:underline" href="/about">About</a>
      </nav>
    </header>

    <main class="flex-1">
      <MarkdownRenderer
        client:load
        title={title}
        author={author}
        date={pubDate}
        content={entry.body}
      />

      <section class="mx-auto mt-4 w-full max-w-3xl px-4 pb-8">
        <p class="text-sm text-gray-400">{formatDate(pubDate)} · {readingTime} min read</p>
        {tags && tags.length > 0 && (
          <ul class="mt-3 flex flex-wrap gap-2">
            {tags.map((tag: string) => (
              <li class="rounded-full border border-white/20 px-3 py-1 text-xs text-gray-200">#{tag}</li>
            ))}
          </ul>
        )}
      </section>

      {relatedPosts.length > 0 && (
        <section class="mx-auto mb-12 w-full max-w-3xl px-4">
          <h2 class="mb-3 text-lg font-semibold">Related posts</h2>
          <ul class="space-y-3">
            {relatedPosts.map((post: any) => (
              <li class="rounded-md border border-white/20 bg-white/5 px-4 py-3">
                <a class="hover:underline" href={`/blog/${post.slug}`}>{post.data.title}</a>
              </li>
            ))}
          </ul>
        </section>
      )}
    </main>

    <footer>
      <div class="p-4 w-full flex justify-center mb-4">
        <a href="https://github.com/tlsenz">
          <img src="/social.png" alt="Logo" class="w-8 h-8" />
        </a>
      </div>
    </footer>
  </body>
</html>
