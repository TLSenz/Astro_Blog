---
import '../styles/global.css';
import { getCollection } from 'astro:content';
import { calculateReadingTime, extractUniqueTags, formatDate, sortPostsByDate } from '../utils/blog';

const allPosts = sortPostsByDate(await getCollection('blog'));
const allTags = extractUniqueTags(allPosts);

const enrichedPosts = allPosts.map((post) => ({
  ...post,
  readingTime: calculateReadingTime(post.body),
}));
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>Thalium&apos;s Blog</title>
  </head>
  <body class="min-h-screen bg-black text-white">
    <header class="mx-auto flex w-full max-w-5xl items-center justify-between px-6 py-6">
      <h1 class="text-xl font-semibold">Thalium&apos;s Blog</h1>
      <nav class="space-x-4 text-sm">
        <a class="hover:underline" href="/">Home</a>
        <a class="hover:underline" href="/about">About</a>
      </nav>
    </header>

    <main class="mx-auto w-full max-w-5xl space-y-8 px-6 pb-14">
      <section class="rounded-lg border border-white/20 bg-white/5 p-6">
        <p class="text-lg">A place where I write about coding, systems, and things I&apos;m learning.</p>
        <div class="mt-4 flex flex-wrap gap-6 text-sm text-gray-300">
          <span><strong>{enrichedPosts.length}</strong> posts</span>
          <span><strong>{allTags.length}</strong> unique topics</span>
        </div>
      </section>

      {allTags.length > 0 && (
        <section>
          <h2 class="mb-3 text-lg font-semibold">Topics</h2>
          <ul class="flex flex-wrap gap-2">
            {allTags.map((tag) => (
              <li class="rounded-full border border-white/20 px-3 py-1 text-sm text-gray-200">#{tag}</li>
            ))}
          </ul>
        </section>
      )}

      <section>
        <h2 class="mb-4 text-lg font-semibold">Latest Posts</h2>
        <ul class="space-y-4">
          {enrichedPosts.map((post) => (
            <li class="rounded-lg border border-white/20 bg-white/5 p-5 transition hover:border-white/40">
              <a href={`/blog/${post.slug}`} class="group block">
                <h3 class="text-lg font-medium group-hover:underline">{post.data.title}</h3>
                <p class="mt-2 text-sm text-gray-300">{post.data.description}</p>
                <p class="mt-3 text-xs uppercase tracking-wide text-gray-400">
                  {formatDate(post.data.pubDate)} · {post.readingTime} min read
                </p>
              </a>
            </li>
          ))}
        </ul>
      </section>
    </main>

    <footer class="p-4">
      <div class="w-full flex justify-center mb-4">
        <a href="https://github.com/tlsenz">
          <img src="/social.png" alt="GitHub logo" class="h-8 w-8" />
        </a>
      </div>
    </footer>
  </body>
</html>
