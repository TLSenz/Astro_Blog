---
import '../styles/global.css';
import { getCollection } from 'astro:content';
import { calculateReadingTime, extractUniqueTags, formatDate, sortPostsByDate } from '../utils/blog';

const allPosts = sortPostsByDate(await getCollection('blog'));
const allTags = extractUniqueTags(allPosts);

const enrichedPosts = allPosts.map((post) => ({
  ...post,
  readingTime: calculateReadingTime(post.body),
}));
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>Thalium&apos;s Blog</title>
  </head>
  <body class="min-h-screen bg-black text-white">
    <header class="mx-auto flex w-full max-w-4xl items-center justify-between px-6 py-8">
      <h1 class="text-xl font-semibold tracking-wide">Thalium&apos;s Blog</h1>
      <nav class="space-x-5 text-sm text-gray-300">
        <a class="transition hover:text-white" href="/">Home</a>
        <a class="transition hover:text-white" href="/about">About</a>
      </nav>
    </header>

    <main class="mx-auto w-full max-w-4xl px-6 pb-16">
      <section class="mb-10 rounded-2xl border border-white/15 bg-gradient-to-b from-white/10 to-white/5 p-7">
        <p class="text-2xl font-semibold leading-tight">Simple notes on coding, systems, and what I&apos;m learning.</p>
        <div class="mt-4 flex flex-wrap gap-5 text-sm text-gray-300">
          <span>{enrichedPosts.length} posts</span>
          <span>{allTags.length} topics</span>
        </div>
      </section>

      {allTags.length > 0 && (
        <section class="mb-10">
          <ul class="flex flex-wrap gap-2">
            {allTags.map((tag) => (
              <li class="rounded-full border border-white/20 px-3 py-1 text-xs text-gray-300 transition hover:border-white/50 hover:text-white">#{tag}</li>
            ))}
          </ul>
        </section>
      )}

      <section>
        <ul class="space-y-4">
          {enrichedPosts.map((post) => (
            <li>
              <a
                href={`/blog/${post.slug}`}
                class="group block rounded-xl border border-white/15 bg-white/5 p-5 transition duration-300 hover:-translate-y-0.5 hover:border-white/40 hover:bg-white/10"
              >
                <div class="flex items-start justify-between gap-4">
                  <h2 class="text-lg font-medium transition group-hover:text-white/95">{post.data.title}</h2>
                  <span class="text-xs text-gray-400">{post.readingTime} min</span>
                </div>
                <p class="mt-2 text-sm text-gray-300">{post.data.description}</p>
                <p class="mt-3 text-xs uppercase tracking-wide text-gray-400">{formatDate(post.data.pubDate)}</p>
              </a>
            </li>
          ))}
        </ul>
      </section>
    </main>

    <footer class="pb-6">
      <div class="w-full flex justify-center">
        <a href="https://github.com/tlsenz" class="transition hover:opacity-80">
          <img src="/social.png" alt="GitHub logo" class="h-8 w-8" />
        </a>
      </div>
    </footer>
  </body>
</html>
